# ===================
# MYSQL
# ===================
DATABASE_URL="mysql://meet:meet@db:3306/meet"

# ===================
# JITSI JWT
# ===================
ENABLE_AUTH=1
ENABLE_GUESTS=0
AUTH_TYPE=jwt
JWT_APP_ID=meetapp
JWT_APP_SECRET=supersecret

JITSI_SECRET=supersecret
JITSI_DOMAIN=localhost:8081

ENABLE_RECORDING=1
ENABLE_FILE_RECORDING=1

MAX_PARTICIPANTS=5